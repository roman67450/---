
#include <Wire.h>
#include <Adafruit_MPU6050.h>
#include <SPI.h>
#include <SD.h>
#include <TinyGPSPlus.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEServer.h>
#include <BLE2902.h>

// ----- BLE -----
#define BLE_DEVICE_NAME "PotholeDetector"
#define SERVICE_UUID        "6E400001-B5A3-F393-E0A9-E50E24DCCA9E"
#define CHARACTERISTIC_UUID "6E400003-B5A3-F393-E0A9-E50E24DCCA9E"

BLECharacteristic *pChar;
bool bleConnected = false;


const char* WIFI_SSID = "pdf";
const char* WIFI_PASS = "123456789";
const char* SHEETDB_URL = "https://sheetdb.io/api/v1/k07alkrni4chg";


#define PIN_SD_CS   10
#define PIN_SD_SCK  4
#define PIN_SD_MOSI 8
#define PIN_SD_MISO 0
#define PIN_I2C_SDA 9
#define PIN_I2C_SCL 7
#define PIN_GPS_RX  20
#define PIN_GPS_TX  21
#define PIN_LED     2


const float IMPACT_THRESH = 0.6;
const unsigned int MIN_GAP_MS = 150;
const unsigned int SILENCE_MS = 300;


Adafruit_MPU6050 mpu;
TinyGPSPlus gps;
HardwareSerial gpsSerial(0);

float baseline = 0.0;
bool inEvent = false;
unsigned long eventStart = 0;
float peakG = 0.0;
unsigned long lastEventEnd = 0;

double curLat = 0.0, curLng = 0.0;
int curSat = 0;
int eventCount = 0;


void ble_notify(String msg);
void connectWiFi();
float getAccelMagnitude();
void calibrateMPU();
void updateGPS();
void initSD();
void saveToSD(float impact, unsigned long dur);
void sendToSheetDB(float impact, unsigned long dur);


class MyServerCallbacks: public BLEServerCallbacks {
  void onConnect(BLEServer* pServer) {
    bleConnected = true;
    Serial.println("BLE client connected");
    ble_notify("BLE connected");
  }
  void onDisconnect(BLEServer* pServer) {
    bleConnected = false;
    Serial.println("BLE disconnected");
    pServer->startAdvertising();
  }
};

class MyCharacteristicCallbacks: public BLECharacteristicCallbacks {
  void onWrite(BLECharacteristic *pCharacteristic) {
    
    Serial.println("BLE write received (ignored)");
  }
};


void ble_notify(String msg) {
  if (bleConnected && pChar != nullptr) {
    pChar->setValue(msg.c_str());
    pChar->notify();
    delay(5);
  }
}


void connectWiFi() {
  Serial.print("Connecting WiFi");
  ble_notify("WiFi connecting...");
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  int tries = 0;
  while (WiFi.status() != WL_CONNECTED && tries < 20) {
    delay(500);
    Serial.print(".");
    tries++;
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println(" OK");
    ble_notify("WiFi OK");
  } else {
    Serial.println(" FAIL");
    ble_notify("WiFi FAIL");
  }
}


float getAccelMagnitude() {
  sensors_event_t a, g, temp;
  mpu.getEvent(&a, &g, &temp);
  float ax = a.acceleration.x / 9.81;
  float ay = a.acceleration.y / 9.81;
  float az = a.acceleration.z / 9.81;
  return sqrt(ax*ax + ay*ay + az*az);
}

void calibrateMPU() {
  Serial.print("Calibrating MPU...");
  ble_notify("Calibrating...");
  float sum = 0;
  for (int i = 0; i < 100; i++) {
    sum += getAccelMagnitude();
    delay(10);
  }
  baseline = sum / 100.0;
  Serial.print(" baseline = ");
  Serial.println(baseline);
  ble_notify("Baseline: " + String(baseline));
}


void updateGPS() {
  while (gpsSerial.available()) {
    gps.encode(gpsSerial.read());
  }
  if (gps.location.isValid()) {
    curLat = gps.location.lat();
    curLng = gps.location.lng();
    curSat = gps.satellites.value();
  }
}


void initSD() {
  SPI.begin(PIN_SD_SCK, PIN_SD_MISO, PIN_SD_MOSI, PIN_SD_CS);
  if (!SD.begin(PIN_SD_CS)) {
    Serial.println("SD init ERROR");
    ble_notify("SD ERROR");
    while (1) delay(100);
  }
  if (!SD.exists("/potholes.csv")) {
    File f = SD.open("/potholes.csv", FILE_WRITE);
    if (f) {
      f.println("Time,Lat,Lon,Impact,Duration,Satellites");
      f.close();
    }
  }
  Serial.println("SD ready");
  ble_notify("SD ready");
}

void saveToSD(float impact, unsigned long dur) {
  File f = SD.open("/potholes.csv", FILE_APPEND);
  if (f) {
    f.print(millis()); f.print(",");
    f.print(curLat, 6); f.print(",");
    f.print(curLng, 6); f.print(",");
    f.print(impact, 3); f.print(",");
    f.print(dur); f.print(",");
    f.println(curSat);
    f.close();
    Serial.println("  [SD saved]");
    ble_notify("SD saved");
  } else {
    Serial.println("  [SD error]");
    ble_notify("SD error");
  }
}


void sendToSheetDB(float impact, unsigned long dur) {
  if (WiFi.status() != WL_CONNECTED) return;
  HTTPClient http;
  http.begin(SHEETDB_URL);
  http.addHeader("Content-Type", "application/json");
  String json = "{";
  json += "\"Time\":\"" + String(millis()) + "\",";
  json += "\"Lat\":" + String(curLat, 6) + ",";
  json += "\"Lon\":" + String(curLng, 6) + ",";
  json += "\"Impact\":" + String(impact, 3) + ",";
  json += "\"Duration\":" + String(dur) + ",";
  json += "\"Satellites\":" + String(curSat);
  json += "}";
  int code = http.POST(json);
  if (code == 200 || code == 201) {
    Serial.println("  [Cloud sent]");
    ble_notify("Cloud sent");
  } else {
    Serial.print("  [Cloud error] ");
    Serial.println(code);
    ble_notify("Cloud err " + String(code));
  }
  http.end();
}


void setup() {
  Serial.begin(115200);
  pinMode(PIN_LED, OUTPUT);
  digitalWrite(PIN_LED, LOW);

  
  BLEDevice::init(BLE_DEVICE_NAME);
  BLEServer *pServer = BLEDevice::createServer();
  pServer->setCallbacks(new MyServerCallbacks());
  BLEService *pService = pServer->createService(SERVICE_UUID);
  pChar = pService->createCharacteristic(
            CHARACTERISTIC_UUID,
            BLECharacteristic::PROPERTY_READ |
            BLECharacteristic::PROPERTY_NOTIFY |
            BLECharacteristic::PROPERTY_WRITE |          // allow write
            BLECharacteristic::PROPERTY_WRITE_NR         // allow write without response
          );
  pChar->addDescriptor(new BLE2902());
  pChar->setCallbacks(new MyCharacteristicCallbacks());  // handle writes
  pService->start();
  pServer->getAdvertising()->start();
  Serial.println("BLE ready, device: " + String(BLE_DEVICE_NAME));
  ble_notify("System starting...");

  
  Wire.begin(PIN_I2C_SDA, PIN_I2C_SCL);
  if (!mpu.begin()) {
    Serial.println("MPU6050 ERROR");
    ble_notify("MPU ERROR");
    while (1) delay(100);
  }
  mpu.setAccelerometerRange(MPU6050_RANGE_2_G);

  
  initSD();

  
  connectWiFi();


  gpsSerial.begin(9600, SERIAL_8N1, PIN_GPS_RX, PIN_GPS_TX);

  
  calibrateMPU();

  Serial.println("System ready");
  ble_notify("System ready");
}


void loop() {
  updateGPS();
  float acc = getAccelMagnitude();
  float diff = acc - baseline;
  unsigned long now = millis();


  if (diff > IMPACT_THRESH && !inEvent && (now - lastEventEnd > MIN_GAP_MS)) {
    inEvent = true;
    eventStart = now;
    peakG = diff;
    Serial.println(">> Pothole start");
    ble_notify("Pothole start");
    digitalWrite(PIN_LED, HIGH);
  }

  
  if (inEvent) {
    if (diff > peakG) peakG = diff;

    static unsigned long lastMove = now;
    if (diff > IMPACT_THRESH * 0.3) lastMove = now;

    if (now - lastMove > SILENCE_MS) {
      inEvent = false;
      unsigned long duration = now - eventStart;
      Serial.print(">> Pothole: ");
      Serial.print(peakG); Serial.print("g, ");
      Serial.print(duration); Serial.println("ms");
      ble_notify("Pothole " + String(peakG,1) + "g " + String(duration) + "ms");

      saveToSD(peakG, duration);
      sendToSheetDB(peakG, duration);
      eventCount++;
      lastEventEnd = now;
      digitalWrite(PIN_LED, LOW);
    }
  }

  
  static unsigned long lastBlink = 0;
  if (now - lastBlink > 2000) {
    lastBlink = now;
    digitalWrite(PIN_LED, HIGH); delay(50); digitalWrite(PIN_LED, LOW);
    String status = "GPS: ";
    if (gps.location.isValid()) {
      status += String(curLat, 6) + "," + String(curLng, 6) + " sat=" + String(curSat);
    } else {
      status += "no fix sat=" + String(curSat);
    }
    status += " ev=" + String(eventCount);
    Serial.println(status);
    ble_notify(status);
  }

  delay(20);
}
